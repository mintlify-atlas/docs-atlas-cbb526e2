{
  "projectType": "saas",
  "projectName": "ICP System",
  "projectDescription": "A network operations dashboard for ISPs to monitor capacity, manage providers, nodes, clients, and service connections with role-based access control.",
  "theme": "luma",
  "primaryColor": "#3B82F6",
  "lightColor": "#EFF6FF",
  "darkColor": "#1E3A5F",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/capacity-dashboard",
              "features/zabbix-monitoring",
              "features/providers",
              "features/services",
              "features/nodes",
              "features/connections",
              "features/clients",
              "features/equipment"
            ]
          },
          {
